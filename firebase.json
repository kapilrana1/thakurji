{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "database.rules.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.php"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin/index.html"
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
